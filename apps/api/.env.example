# ─── Server ─────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# ─── Database ────────────────────────────────────────
# 로컬: postgresql://postgres:postgres@localhost:5432/yajang_db
# 프로덕션: Railway PostgreSQL 연결 문자열 (Railway 대시보드 → PostgreSQL 플러그인 → Connect 탭)
# 내부 URL (Railway 서비스 내부 통신용): postgresql://postgres:<PASSWORD>@postgres.railway.internal:5432/railway
# 외부 URL (로컬에서 Railway DB 접근 시): Railway 대시보드에서 확인
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yajang_db

# ─── CORS ────────────────────────────────────────────
# 로컬: http://localhost:3000
# 프로덕션: Vercel 배포 URL
CORS_ORIGIN=http://localhost:3000

# ─── 공공데이터 시딩 (선택) ──────────────────────────
# data.go.kr → 식품안전나라 일반음식점 인허가 API 키
# pnpm seed:public 실행 시 필요
PUBLIC_DATA_API_KEY=

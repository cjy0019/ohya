{
  "name": "@oneul-yajang/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "seed": "tsx src/scripts/seed-public-data.ts",
    "seed:public": "tsx src/scripts/seed-public-data.ts --public"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.2.2",
    "pg": "^8.13.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
